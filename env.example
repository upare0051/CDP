# =============================================================================
# Alo ActivationOS - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp env.example .env
# =============================================================================

# =============================================================================
# Application
# =============================================================================
APP_NAME=Alo ActivationOS
APP_ENV=development
DEBUG_MODE=true
SECRET_KEY=your-secret-key-change-in-production

# =============================================================================
# API
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:5173
PUBLIC_DEMO_URL=http://localhost/dashboard

# =============================================================================
# Transaction Database - PostgreSQL (Cloud SQL in production)
# =============================================================================
# Local example:
# DATABASE_URL=postgresql://activationos:activationos@localhost:5432/activationos
# Cloud SQL example:
# DATABASE_URL=postgresql+psycopg2://activationos_app:<password>@<cloud-sql-public-ip>:5432/activationos
DATABASE_URL=postgresql://activationos:activationos@localhost:5432/activationos
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# =============================================================================
# Cache - Redis
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=10
CACHE_TTL_SECONDS=300

# =============================================================================
# Object Storage - S3 Compatible (MinIO for local dev)
# =============================================================================
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=activationos
STORAGE_REGION=us-east-1
STORAGE_USE_SSL=false

# =============================================================================
# Analytics / Marts Warehouse
# =============================================================================
# Local dev: duckdb
# Production: bigquery
WAREHOUSE_MODE=duckdb
DUCKDB_PATH=:memory:

# BigQuery (production analytics/marts)
BIGQUERY_PROJECT_ID=prime-force-250304
BIGQUERY_DATASET=activationos_analytics
BIGQUERY_LOCATION=US

# Redshift (optional)
# Leadership local tunnel example:
REDSHIFT_HOST=localhost
REDSHIFT_PORT=10005
REDSHIFT_USER=utkarsh.parekh
REDSHIFT_PASSWORD=password
REDSHIFT_DATABASE=dev

# C360 runtime guardrails (match leadership setup by default)
C360_REDSHIFT_SSL=false
C360_QUERY_TIMEOUT_SECONDS=30
C360_MAX_ROWS=200

# Ollama (host process)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_TEMPERATURE=0.3
OLLAMA_MAX_TOKENS=1200

# =============================================================================
# dbt Transformations (DuckDB local-first)
# =============================================================================
DBT_DUCKDB_PATH=platform/dbt/activationos_transform.duckdb
DBT_DUCKDB_SCHEMA=main
DBT_ACTIVATIONOS_SQLITE_PATH=activationos.db
DBT_ACTIVATIONOS_SOURCE_DATABASE=activationos_src
DBT_ACTIVATIONOS_SCHEMA=main
DBT_THREADS=4

# =============================================================================
# Security
# =============================================================================
ENCRYPTION_KEY=your-encryption-key-change-in-production
ADMIN_ANALYTICS_KEY=your-admin-analytics-key-for-internal-use

# =============================================================================
# Sync Settings
# =============================================================================
MAX_RETRIES=3
RETRY_DELAY_SECONDS=60
SYNC_BATCH_SIZE=1000
