activationos_transform:
  target: duckdb_local
  outputs:
    duckdb_local:
      type: duckdb
      path: "{{ env_var('DBT_DUCKDB_PATH', 'platform/dbt/activationos_transform.duckdb') }}"
      schema: "{{ env_var('DBT_DUCKDB_SCHEMA', 'main') }}"
      threads: "{{ env_var('DBT_THREADS', '4') | int }}"
      attach:
        - path: "{{ env_var('DBT_ACTIVATIONOS_SQLITE_PATH', 'activationos.db') }}"
          type: sqlite
          alias: "{{ env_var('DBT_ACTIVATIONOS_SOURCE_DATABASE', 'activationos_src') }}"
